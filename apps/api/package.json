{
  "name": "api",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check-types": "tsc --noEmit -p tsconfig.json",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "dev": "portless run --name api.ceird tsx watch src/index.ts",
    "sandbox:dev": "tsx watch src/index.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@ceird/identity-core": "workspace:*",
    "@ceird/jobs-core": "workspace:*",
    "@ceird/labels-core": "workspace:*",
    "@ceird/sandbox-core": "workspace:*",
    "@ceird/sites-core": "workspace:*",
    "@effect/platform": "^0.96.1",
    "@effect/platform-node": "^0.106.0",
    "@effect/sql": "0.51.0",
    "@effect/sql-drizzle": "0.50.0",
    "@effect/sql-pg": "0.52.1",
    "@sentry/cloudflare": "10.51.0",
    "@sentry/effect": "10.51.0",
    "better-auth": "1.5.6",
    "cloudflare": "6.0.0-beta.2",
    "drizzle-orm": "0.45.2",
    "effect": "^3.21.2",
    "pg": "8.20.0",
    "uuid": "11.1.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260501.1",
    "@effect/language-service": "^0.84.3",
    "@types/node": "^25.6.0",
    "@types/pg": "8.15.6",
    "drizzle-kit": "0.31.10",
    "tsx": "^4.21.0",
    "vitest": "3.0.5"
  }
}
