{
  "name": "api",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check-types": "tsc --noEmit -p tsconfig.json",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "dev": "portless run --name api.task-tracker tsx watch src/index.ts",
    "dev:raw": "tsx watch src/index.ts",
    "sandbox:dev": "tsx watch src/index.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@effect/platform": "^0.96.0",
    "@effect/platform-node": "^0.106.0",
    "@effect/sql": "0.51.0",
    "@effect/sql-drizzle": "0.50.0",
    "@effect/sql-pg": "0.50.0",
    "@task-tracker/sandbox-core": "workspace:*",
    "better-auth": "1.5.6",
    "drizzle-orm": "0.45.2",
    "effect": "^3.21.0",
    "pg": "8.20.0"
  },
  "devDependencies": {
    "@effect/language-service": "^0.84.2",
    "@types/node": "^25.5.0",
    "@types/pg": "8.15.6",
    "drizzle-kit": "0.31.10",
    "tsx": "^4.21.0",
    "vitest": "3.0.5"
  }
}
