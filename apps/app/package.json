    "@ceird/sites-core": "workspace:*",
    "@effect-atom/atom-react": "^0.5.0",
    "@effect/platform": "^0.96.1",
    "@fontsource-variable/geist": "^5.2.8",
    "@fontsource-variable/raleway": "^5.2.8",
