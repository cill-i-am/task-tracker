{
  "name": "ceird",
  "private": true,
  "scripts": {
    "alchemy": "node packages/infra/scripts/alchemy-env.mjs",
    "build": "turbo run build",
    "check": "ultracite check .",
    "check-types": "turbo run check-types",
    "dev": "pnpm alchemy dev",
    "fix": "ultracite fix .",
    "format": "oxfmt --check .",
    "format:write": "oxfmt --write .",
    "infra:bootstrap:cloudflare": "pnpm alchemy bootstrap cloudflare",
    "infra:check-types": "pnpm --filter @ceird/infra check-types",
    "infra:deploy": "pnpm alchemy deploy",
    "infra:destroy": "pnpm alchemy destroy",
    "infra:dev": "pnpm alchemy dev",
    "lint": "oxlint --config .oxlintrc.mjs . --ignore-pattern '.agents/**' --ignore-pattern 'opensrc/**' --ignore-pattern 'apps/app/src/routeTree.gen.ts'",
    "opensrc:sync": "node scripts/sync-opensrc.mjs",
    "postinstall": "pnpm run opensrc:sync",
    "prebuild": "pnpm run opensrc:sync",
    "prepare": "node scripts/prepare.mjs",
    "test": "turbo run test && pnpm run test:scripts",
    "test:scripts": "node --test scripts/*.test.mjs"
  },
  "devDependencies": {
    "alchemy": "2.0.0-beta.40",
    "effect": "4.0.0-beta.66",
    "lefthook": "^2.1.6",
    "opensrc": "^0.6.0",
    "oxfmt": "^0.43.0",
    "oxlint": "^1.62.0",
    "portless": "^0.9.6",
    "turbo": "^2.9.7",
    "typescript": "5.9.2",
    "ultracite": "^7.6.2"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "4.60.1"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@9.15.9",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lefthook",
      "lightningcss"
    ],
    "supportedArchitectures": {
      "cpu": [
        "current",
        "x64"
      ],
      "libc": [
        "current",
        "glibc"
      ],
      "os": [
        "current",
        "linux"
      ]
    }
  }
}
