{
  "name": "task-tracker",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "check": "ultracite check .",
    "check-types": "turbo run check-types",
    "dev": "node scripts/dev.mjs",
    "fix": "ultracite fix .",
    "format": "oxfmt --check .",
    "format:write": "oxfmt --write .",
    "lint": "oxlint . --ignore-pattern '.agents/**' --ignore-pattern 'opensrc/**' --ignore-pattern 'apps/app/src/routeTree.gen.ts'",
    "opensrc:sync": "node scripts/sync-opensrc.mjs",
    "postinstall": "pnpm run opensrc:sync",
    "prebuild": "pnpm run opensrc:sync",
    "prepare": "node scripts/prepare.mjs",
    "sandbox:down": "pnpm --dir packages/sandbox-cli exec tsx src/cli.ts down",
    "sandbox:list": "pnpm --dir packages/sandbox-cli exec tsx src/cli.ts list",
    "sandbox:logs": "pnpm --dir packages/sandbox-cli exec tsx src/cli.ts logs",
    "sandbox:status": "pnpm --dir packages/sandbox-cli exec tsx src/cli.ts status",
    "sandbox:up": "pnpm --dir packages/sandbox-cli exec tsx src/cli.ts up",
    "sandbox:url": "pnpm --dir packages/sandbox-cli exec tsx src/cli.ts url",
    "test": "turbo run test"
  },
  "devDependencies": {
    "lefthook": "^2.1.4",
    "opensrc": "^0.6.0",
    "oxfmt": "^0.43.0",
    "oxlint": "^1.58.0",
    "portless": "^0.9.1",
    "turbo": "^2.9.3",
    "typescript": "5.9.2",
    "ultracite": "^7.4.2"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "4.60.1"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@9.0.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lefthook",
      "lightningcss"
    ]
  }
}
