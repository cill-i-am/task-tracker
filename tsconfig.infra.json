{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "types": ["bun", "node"],
    "plugins": [{ "name": "@effect/language-service" }]
  },
  "include": ["alchemy.run.ts", "infra/**/*.ts", "infra/**/*.d.ts"]
}
