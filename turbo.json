{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "tasks": {
    "transit": {
      "dependsOn": ["^transit"]
    },
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"]
    },
    "lint": {
      "dependsOn": ["transit"]
    },
    "check-types": {
      "dependsOn": ["transit"]
    },
    "test": {
      "dependsOn": ["^test"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "sandbox:dev": {
      "cache": false,
      "persistent": true,
      "env": [
        "AUTH_EMAIL_FROM",
        "AUTH_EMAIL_FROM_NAME",
        "AUTH_ORIGIN",
        "BETTER_AUTH_BASE_URL",
        "BETTER_AUTH_SECRET",
        "CLOUDFLARE_ACCOUNT_ID",
        "CLOUDFLARE_API_TOKEN",
        "DATABASE_URL",
        "HOST",
        "PNPM_STORE_DIR",
        "PORT",
        "SANDBOX_ID",
        "TASK_TRACKER_SANDBOX",
        "VITE_AUTH_ORIGIN"
      ]
    },
    "sandbox:up": {
      "cache": false
    },
    "sandbox:down": {
      "cache": false
    },
    "sandbox:status": {
      "cache": false
    },
    "sandbox:list": {
      "cache": false
    },
    "sandbox:logs": {
      "cache": false
    },
    "sandbox:url": {
      "cache": false
    }
  }
}
