{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "tasks": {
    "transit": {
      "dependsOn": ["^transit"]
    },
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"]
    },
    "lint": {
      "dependsOn": ["transit"]
    },
    "check-types": {
      "dependsOn": ["transit"]
    },
    "react-doctor": {
      "dependsOn": ["transit"],
      "outputs": []
    },
    "test": {
      "dependsOn": ["^test"],
      "env": [
        "API_TEST_DATABASE_URL",
        "AUTH_TEST_DATABASE_URL",
        "DATABASE_URL",
        "TEST_DATABASE_URL"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
