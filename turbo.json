{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "tasks": {
    "transit": {
      "dependsOn": ["^transit"]
    },
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"]
    },
    "lint": {
      "dependsOn": ["transit"]
    },
    "check-types": {
      "dependsOn": ["transit"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "sandbox:dev": {
      "cache": false,
      "persistent": true,
      "env": [
        "BETTER_AUTH_SECRET",
        "DATABASE_URL",
        "HOST",
        "PNPM_STORE_DIR",
        "PORT",
        "SANDBOX_ID",
        "TASK_TRACKER_SANDBOX"
      ]
    },
    "sandbox:up": {
      "cache": false
    },
    "sandbox:down": {
      "cache": false
    },
    "sandbox:status": {
      "cache": false
    },
    "sandbox:list": {
      "cache": false
    },
    "sandbox:logs": {
      "cache": false
    },
    "sandbox:url": {
      "cache": false
    }
  }
}
